# Akmatori Configuration
#
# All secrets are auto-generated on first run.
# Set these only if you want to override the defaults.

# Admin password — set via web UI on first access (setup wizard)
# Uncomment to override and skip the setup wizard:
# ADMIN_PASSWORD=

# PostgreSQL password — auto-generated to akmatori_data/secrets/postgres_password
# Uncomment to override:
# POSTGRES_PASSWORD=

# JWT secret — auto-generated and stored in the database
# Uncomment to override:
# JWT_SECRET=

# HTTP port for the proxy (default: 8080)
HTTP_PORT=8080

# PostgreSQL configuration (optional)
# POSTGRES_USER=akmatori
# POSTGRES_DB=akmatori

# LLM Provider Configuration
# NOTE: LLM provider, API key, and model are configured in the web UI
# under Settings > LLM Provider. No environment variables needed.
# Supported providers: openai, anthropic, google, openrouter, custom
